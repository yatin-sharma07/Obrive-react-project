generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model events {
  id              Int       @id @default(autoincrement())
  title           String    @db.VarChar(255)
  description     String?
  event_date      DateTime  @db.Date
  event_time      DateTime? @db.Time(6)
  end_date        DateTime? @db.Date
  end_time        DateTime? @db.Time(6)
  location        String?   @db.VarChar(255)
  event_type      String?   @default("general") @db.VarChar(50)
  created_by      Int?
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  updated_at      DateTime? @default(now()) @db.Timestamp(6)
  category        String?   @db.VarChar(50)
  priority        String?   @default("medium") @db.VarChar(20)
  is_recurring    Boolean?  @default(false)
  repeat_type     String?   @db.VarChar(20)
  repeat_days     String?   @db.VarChar(100)
  repeat_end_date DateTime? @db.Date
  users           users?    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_by], map: "idx_events_created_by")
  @@index([event_date], map: "idx_events_event_date")
}

model login_logs {
  id              Int       @id @default(autoincrement())
  userId          Int
  ipAddress       String?
  userAgent       String?
  loginTime       DateTime  @default(now())
  logoutTime      DateTime?
  sessionDuration Int?
  users           users     @relation(fields: [userId], references: [id])
}

model project_assignments {
  id          Int       @id @default(autoincrement())
  project_id  Int?
  employee_id Int?
  users       users?    @relation(fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  projects    projects? @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([project_id, employee_id])
}

model projects {
  id                  Int                   @id @default(autoincrement())
  project_id          String                @unique @db.VarChar(50)
  name                String                @db.VarChar(255)
  description         String?
  priority            String?               @db.VarChar(20)
  deadline            DateTime?             @db.Date
  progress            Int                   @default(0)
  leader_id           Int?
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  project_status  String?  @db.Text
  client_id       String?  @db.VarChar(255)
  project_assignments project_assignments[]
  tasks               tasks[]
  leader              users?                @relation("ProjectLeader", fields: [leader_id], references: [id])
}

model sticky_notes {
  id         Int       @id @default(autoincrement())
  user_id    Int
  content    String?
  color      String?   @default("yellow") @db.VarChar(20)
  note_date  DateTime  @db.Date
  position   Int
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user")
}

model tasks {
  id          Int       @id @default(autoincrement())
  project_id  Int?
  task_number String    @db.VarChar(20)
  title       String    @db.VarChar(255)
  description String?
  deadline    DateTime? @db.Date
  status      String?   @default("pending") @db.VarChar(20)
  assigned_to Int?
  created_by  Int?
  location    String?   @db.VarChar(255)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
  assigned_user  users?    @relation("TaskAssignedTo", fields: [assigned_to], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creator        users?    @relation("TaskCreatedBy", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projects    projects? @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([project_id], map: "idx_tasks_project_id")
  @@index([assigned_to], map: "idx_tasks_assigned_to")
  @@index([created_by], map: "idx_tasks_created_by")
}

model users {
  id                  Int                   @id @default(autoincrement())
  userid              String                @unique(map: "unique_employee_id") @db.VarChar(50)
  email               String                @unique @db.VarChar(255)
  name                String                @db.VarChar(100)
  role                String                @db.VarChar(50)
  password            String                @db.VarChar(255)
  status              String                @default("offline") @db.VarChar(50)
  created_at          DateTime              @default(now())
  updated_at          DateTime
  department          String?               @db.VarChar(255)
  biography           String?
  is_active           Boolean               @default(true)
  job_title           String?               @db.VarChar(255)
  join_date           DateTime?
  phone_number        String?               @db.VarChar(25)
  date_of_birth       DateTime?             @db.Date
  bio                 String?
  events              events[]
  login_logs          login_logs[]
  leave_requests      leave_requests[]
  project_assignments project_assignments[]
  sticky_notes        sticky_notes[]
  tasks_assigned      tasks[]               @relation("TaskAssignedTo")
  tasks_created       tasks[]               @relation("TaskCreatedBy")
  projects_led        projects[]            @relation("ProjectLeader")
  work_sessions       work_sessions[]
  leaves              leaves[]
  approved_leaves     leaves[]              @relation("LeaveApprovedBy")
  room_configs        room_configs[]
  handRaises          room_hand_raises[]
  
  // Chat relations
  created_conversations conversations[]     @relation("CreatedConversations")
  conversations         conversation_participants[]
  messages              messages[]
  unread_conversations  conversation_unread[]
  roomParticipants      room_participants[]

  //Room relations
  room_role_assignments room_role_assignments[] @relation("RoomRoleAssignmentUser")
  room_invites room_invites[] @relation("RoomInviteUser")
}

model leaves {
  id              Int       @id @default(autoincrement())
  user_id         Int
  leave_type      String    @db.VarChar(50)  // 'vacation', 'sick_leave', 'work_remotely'
  start_date      DateTime  @db.Date
  end_date        DateTime  @db.Date
  status          String    @default("pending") @db.VarChar(20)  // 'pending', 'approved', 'rejected'
  reason          String?
  approved_by     Int?
  created_at      DateTime  @default(now()) @db.Timestamp(6)
  updated_at      DateTime  @default(now()) @db.Timestamp(6)
  users           users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  approver        users?    @relation("LeaveApprovedBy", fields: [approved_by], references: [id], onDelete: NoAction)

  @@index([user_id], map: "idx_leaves_user_id")
  @@index([start_date], map: "idx_leaves_start_date")
  @@index([status], map: "idx_leaves_status")
}

model work_sessions {
  id                  Int       @id @default(autoincrement())

  userId              Int

  sessionStart        DateTime  @default(now())

  startedAt           DateTime?

  lastHeartbeat       DateTime? @default(now())

  sessionEnd          DateTime?

  workDate            DateTime? @default(now()) @db.Date

  totalActiveDuration Int       @default(0)

  status              String    @default("active")

  isAutoEnded         Boolean   @default(false)

  created_at          DateTime  @default(now())

  updated_at          DateTime  @updatedAt

  users               users     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, workDate])

  @@index([status])
}

model leave_requests {
  id         Int       @id @default(autoincrement())
  user_id    Int
  leave_date DateTime  @db.Date
  leave_type String    @db.VarChar(20)
  reason     String?
  status     String    @default("pending") @db.VarChar(20)
  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime  @updatedAt @db.Timestamp(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, leave_date], map: "leave_requests_user_id_leave_date_key")
  @@index([leave_date], map: "idx_leave_requests_leave_date")
  @@index([user_id], map: "idx_leave_requests_user_id")
  @@index([status], map: "idx_leave_requests_status")
}


model conversations {
  id            Int       @id @default(autoincrement())
  type          String    @default("direct") // direct | group
  name          String?   @db.VarChar(255)
  created_by    Int
  created_at    DateTime  @default(now())

  creator       users     @relation("CreatedConversations", fields: [created_by], references: [id])

  participants  conversation_participants[]
  messages      messages[]
  unread_counts conversation_unread[]

  @@index([created_by])
}

model conversation_participants {
  id               Int      @id @default(autoincrement())
  conversation_id  Int
  user_id          Int
  joined_at        DateTime @default(now())
  is_hidden        Boolean  @default(false)
  deleted_until    DateTime? // Hide messages sent before this date
  last_read_at     DateTime?

  conversation     conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  user             users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([conversation_id, user_id])

  @@index([user_id])
  @@index([conversation_id])
}

model messages {
  id               BigInt    @id @default(autoincrement())
  conversation_id  Int
  sender_id        Int?
  content          String
  type             String    @default("text") // text | system

  created_at       DateTime  @default(now())

  is_edited        Boolean   @default(false)

  conversation     conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  sender           users? @relation(fields: [sender_id], references: [id])

  @@index([conversation_id, created_at])
  @@index([sender_id])
}

model conversation_unread {
  id               Int      @id @default(autoincrement())

  user_id          Int
  conversation_id  Int

  unread_count     Int      @default(0)

  updated_at       DateTime @updatedAt

  user             users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  conversation     conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@unique([user_id, conversation_id])

  @@index([user_id])
}



//=======================================================================================
//|| ROOM MODELS
//=======================================================================================

//=======================================================================================
model room_configs {
  id                      Int      @id @default(autoincrement())

  roomName                String   @db.VarChar(100)
  roomDescription         String?  @db.Text

  roomType                String   @db.VarChar(50)
  roomStatus              String   @default("draft") @db.VarChar(50)

  startTime               DateTime?
  endTime                 DateTime?

  participantLimit        Int

  visibility              String   @db.VarChar(50)

  allowGuestUsers         Boolean  @default(false)

  guestJoinMode           String?  @db.VarChar(50)

  createdBy               Int?
  creator                 users?   @relation(fields: [createdBy], references: [id])

  notificationSettings    Json?

  redirectAfterRoomEnd    String?  @default("/room-ended")

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  roleAssignments         room_role_assignments[]
  joinPermissions         room_join_permissions[]
  invites                 room_invites[]
  notifications           room_notifications[]
  participants            room_participants[]
  handRaises              room_hand_raises[]

  @@index([createdBy])
  @@index([roomStatus])
  @@index([visibility])
  @@index([startTime])
}
//=======================================================================================
model room_join_permissions {
  id                 Int      @id @default(autoincrement())

  roomConfigId       Int
  roomConfig         room_configs @relation(fields: [roomConfigId], references: [id], onDelete: Cascade)

  permissionType     String   @db.VarChar(50)
  crmRole            String?  @db.VarChar(50)

  createdAt          DateTime @default(now())

  @@index([roomConfigId])
}

//=======================================================================================
model room_role_assignments {
  id                   Int      @id @default(autoincrement())

  roomConfigId         Int
  roomConfig           room_configs @relation(fields: [roomConfigId], references: [id], onDelete: Cascade)

  assignmentType       String   @db.VarChar(50)
  crmRole              String?  @db.VarChar(50)

  userId               Int?
  user                 users? @relation("RoomRoleAssignmentUser", fields: [userId], references: [id])

  assignedRoomRole     String   @db.VarChar(50)

  createdAt            DateTime @default(now())

  @@index([roomConfigId])
  @@index([userId])
}

//=======================================================================================
model room_invites {
  id                  Int      @id @default(autoincrement())

  roomConfigId        Int
  roomConfig          room_configs @relation(fields: [roomConfigId], references: [id], onDelete: Cascade)

  inviteToken         String   @unique

  inviteRole          String   @db.VarChar(50)

  invitedUserId       Int?

  invitedUser users? @relation("RoomInviteUser", fields: [invitedUserId], references: [id])

  guestEmail          String?

  requiresPasskey     Boolean  @default(false)

  passkey             String?

  status              String   @default("active") @db.VarChar(50)

  expiresAt           DateTime?

  createdBy           Int?

  createdAt           DateTime @default(now())

  @@index([roomConfigId])
}
//=======================================================================================
model room_templates {
  id                   Int      @id @default(autoincrement())

  templateName         String   @db.VarChar(100)

  createdBy            Int?

  configurationData    Json

  createdAt            DateTime @default(now())
}
//=======================================================================================
model room_notifications {
  id                  Int      @id @default(autoincrement())

  roomConfigId        Int
  roomConfig          room_configs @relation(fields: [roomConfigId], references: [id], onDelete: Cascade)

  notificationType    String   @db.VarChar(50)

  scheduledTime       DateTime

  status              String   @default("pending") @db.VarChar(50)

  createdAt           DateTime @default(now())

  @@index([roomConfigId])
}

//=======================================================================================
model room_participants {
  id          Int      @id @default(autoincrement())
  roomId      Int
  userId      Int
  roomRole    String
  joinedAt    DateTime @default(now())
  leftAt      DateTime?
  isMuted     Boolean @default(true)
  isSpeaking  Boolean @default(false)

  room        room_configs @relation(fields: [roomId], references: [id])
  user users @relation(fields: [userId], references: [id])
}

//=======================================================================================
model room_hand_raises {
  id            Int       @id @default(autoincrement())

  roomId        Int
  userId        Int

  status        String    @default("pending")
  requestedAt   DateTime  @default(now())
  respondedAt   DateTime?

  room          room_configs @relation(fields: [roomId], references: [id])
  user          users @relation(fields: [userId], references: [id])
}