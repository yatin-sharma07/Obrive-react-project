generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Users {
  id          Int         @id @default(autoincrement())
  userid      String      @unique
  email       String      @unique
  name        String
  role        String
  password    String
  status      String      @default("offline")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @default(now()) @updatedAt @map("updated_at")
  isActive    Boolean      @default(true)
  jobTitle    String?      @db.VarChar(255) @map("jobtitle")
  department  String?     @db.VarChar(255)
  phoneNumber String?     @db.VarChar(20) @map("phonenumber")
  joinDate    String?     @db.VarChar(50) @map("joindate")
  biography   String?
  login_logs  login_logs[]
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp()
  
  @@map("users")
}

model login_logs {
  id              Int       @id @default(autoincrement())
  userId          Int
  ipAddress       String?
  userAgent       String?
  loginTime       DateTime  @default(now())
  logoutTime      DateTime?
  sessionDuration Int?
  users           Users     @relation(fields: [userId], references: [id])
}


enum UserRole {
  client
  employee
  HR
  Admin
}