// backend/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Users model based on your database table
model Users {
  id          Int      @id @default(autoincrement())
  userid      String   @unique @db.VarChar(50)
  name        String   @db.VarChar(100)
  role        String
  email       String   @unique @db.VarChar(255)
  password    String   @db.VarChar(255)
  status      String   @db.VarChar(50)
  department  String?  @db.VarChar(100)
  biography   String?  @db.Text()
  is_active   Boolean? @default(true)
  job_title   String?  @db.VarChar(100)
  join_date   DateTime? @db.Timestamp()
  phone_number String? @db.VarChar(20)
  date_of_birth DateTime? @db.Date()
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp()
  
  @@map("users")
}

enum UserRole {
  client
  employee
  HR
  Admin
}