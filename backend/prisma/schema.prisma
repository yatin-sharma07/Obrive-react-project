generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Users {
  id                  Int                   @id @default(autoincrement())
  userid              String                @unique(map: "unique_employee_id") @db.VarChar(50)
  email               String                @unique @db.VarChar(255)
  name                String                @db.VarChar(100)
  role                String                @db.VarChar(50)
  password            String                @db.VarChar(255)
  status              String                @default("offline") @db.VarChar(50)
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")
  department          String?               @db.VarChar(255)
  biography           String?
  is_active           Boolean               @default(true)
  job_title           String?               @db.VarChar(255)
  join_date           DateTime?
  phone_number        String?               @db.VarChar(25)
  date_of_birth       DateTime?             @db.Date
  bio                 String?
  events              events[]
  login_logs          login_logs[]
  project_assignments project_assignments[]
  stickyNotes         StickyNote[]
  tasks               tasks[]

  @@map("users")
}

model StickyNote {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  content   String?
  color     String?   @default("yellow") @db.VarChar(20)
  noteDate  DateTime  @map("note_date") @db.Date
  position  Int
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  user      Users     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user")

  @@map("sticky_notes")
}

model events {
  id              Int       @id @default(autoincrement())
  title           String    @db.VarChar(255)
  description     String?
  event_date      DateTime  @db.Date
  event_time      DateTime? @db.Time(6)
  end_date        DateTime? @db.Date
  end_time        DateTime? @db.Time(6)
  location        String?   @db.VarChar(255)
  event_type      String?   @default("general") @db.VarChar(50)
  created_by      Int?
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  updated_at      DateTime? @default(now()) @db.Timestamp(6)
  category        String?   @db.VarChar(50)
  priority        String?   @default("medium") @db.VarChar(20)
  is_recurring    Boolean?  @default(false)
  repeat_type     String?   @db.VarChar(20)
  repeat_days     String?   @db.VarChar(100)
  repeat_end_date DateTime? @db.Date
  users           Users?    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_by], map: "idx_events_created_by")
  @@index([event_date], map: "idx_events_event_date")
}

model login_logs {
  id              Int       @id @default(autoincrement())
  userId          Int
  ipAddress       String?
  userAgent       String?
  loginTime       DateTime  @default(now())
  logoutTime      DateTime?
  sessionDuration Int?
  users           Users     @relation(fields: [userId], references: [id])
}

model project_assignments {
  id          Int       @id @default(autoincrement())
  project_id  Int?
  employee_id Int?
  users       Users?    @relation(fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  projects    projects? @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([project_id, employee_id])
}

model projects {
  id                  Int                   @id @default(autoincrement())
  project_id          String                @unique @db.VarChar(50)
  name                String                @db.VarChar(255)
  description         String?
  priority            String?               @db.VarChar(20)
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  project_assignments project_assignments[]
  tasks               tasks[]
}

model tasks {
  id          Int       @id @default(autoincrement())
  project_id  Int?
  task_number String    @db.VarChar(20)
  title       String    @db.VarChar(255)
  description String?
  deadline    DateTime? @db.Date
  status      String?   @default("pending") @db.VarChar(20)
  assigned_to Int?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  users       Users?    @relation(fields: [assigned_to], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projects    projects? @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}
